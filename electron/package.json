{
  "name": "evolubrowser",
  "version": "0.1.0",
  "description": "EvoluBrowser - AI-powered cross-platform browser",
  "author": "Lance",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.evolu.browser",
    "productName": "EvoluBrowser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "web",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "../assets/favicon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
